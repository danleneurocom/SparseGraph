{
  "seed": 7,
  "device": "mps",
  "output_dir": "runs/toposparsenet_fisbe_consensus_mps",
  "model": {
    "in_channels": 4,
    "base_channels": 32,
    "channel_multipliers": [1, 2, 4, 8],
    "use_attention": true,
    "affinity_channels": 2,
    "use_topology_refinement": true,
    "topology_variant": "consensus_rollout"
  },
  "data": {
    "dataset_type": "npz",
    "train_dir": "data/fisbe_npz/train",
    "val_dir": "data/fisbe_npz/val",
    "image_size": 256,
    "train_samples": 0,
    "val_samples": 0,
    "batch_size": 2,
    "num_workers": 0
  },
  "training": {
    "epochs": 20,
    "lr": 0.0005,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "log_every": 10
  },
  "loss": {
    "mask": 1.0,
    "skeleton": 1.0,
    "topology": 0.8,
    "node": 0.6,
    "affinity": 0.2,
    "uncertainty": 0.05,
    "auxiliary": 0.2,
    "consistency": 0.1,
    "graph": 0.0,
    "skeleton_iterations": 10
  },
  "postprocess": {
    "node_threshold": 0.45,
    "skeleton_threshold": 0.45,
    "max_neighbor_distance": 24,
    "min_path_support": 0.3,
    "max_neighbors_per_node": 3
  }
}
